# Jenkins environment example

# Jenkins controller
JENKINS_URL="http://jenkins.example.local"
JENKINS_USER="admin"
JENKINS_TOKEN="<replace-me>"

# Job / pipeline registration
JENKINS_JOB_NAME="kube-local"
JENKINS_REPO_URL="https://github.com/young3881042-commits/Kube_Local.git"
JENKINS_BRANCH="main"
JENKINSFILE_PATH="Jenkinsfile"

# Optional deployment wiring
JENKINS_AGENT_LABEL="k8s"
JENKINS_NAMESPACE="jenkins"
JENKINS_CREDENTIAL_ID="kube-local-git-token"
